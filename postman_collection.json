{
	"info": {
		"name": "Attendance Management System API",
		"description": "Complete API collection for CSE 405 Attendance Management System.\n\nBASE_URL: http://127.0.0.1:8000\n\nHow to use:\n1. Run 'Login as Admin' to get tokens\n2. Token auto-saves to collection variables\n3. All other requests use the saved token automatically",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{access_token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://127.0.0.1:8000"
		},
		{
			"key": "access_token",
			"value": ""
		},
		{
			"key": "refresh_token",
			"value": ""
		}
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register User",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"newstudent\",\n  \"email\": \"new@test.com\",\n  \"password\": \"test1234\",\n  \"first_name\": \"New\",\n  \"last_name\": \"Student\"\n}"
						},
						"url": { "raw": "{{base_url}}/api/auth/register/", "host": ["{{base_url}}"], "path": ["api", "auth", "register", ""] }
					}
				},
				{
					"name": "Login as Admin",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"admin\",\n  \"password\": \"test1234\"\n}"
						},
						"url": { "raw": "{{base_url}}/api/auth/login/", "host": ["{{base_url}}"], "path": ["api", "auth", "login", ""] }
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var res = pm.response.json();",
									"pm.collectionVariables.set('access_token', res.access);",
									"pm.collectionVariables.set('refresh_token', res.refresh);",
									"console.log('Tokens saved! Access: ' + res.access.substring(0, 30) + '...');"
								]
							}
						}
					]
				},
				{
					"name": "Login as Faculty",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"faculty1\",\n  \"password\": \"test1234\"\n}"
						},
						"url": { "raw": "{{base_url}}/api/auth/login/", "host": ["{{base_url}}"], "path": ["api", "auth", "login", ""] }
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var res = pm.response.json();",
									"pm.collectionVariables.set('access_token', res.access);",
									"pm.collectionVariables.set('refresh_token', res.refresh);"
								]
							}
						}
					]
				},
				{
					"name": "Login as Student",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"student1\",\n  \"password\": \"test1234\"\n}"
						},
						"url": { "raw": "{{base_url}}/api/auth/login/", "host": ["{{base_url}}"], "path": ["api", "auth", "login", ""] }
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var res = pm.response.json();",
									"pm.collectionVariables.set('access_token', res.access);",
									"pm.collectionVariables.set('refresh_token', res.refresh);"
								]
							}
						}
					]
				},
				{
					"name": "Refresh Token",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
						},
						"url": { "raw": "{{base_url}}/api/auth/token/refresh/", "host": ["{{base_url}}"], "path": ["api", "auth", "token", "refresh", ""] }
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var res = pm.response.json();",
									"pm.collectionVariables.set('access_token', res.access);"
								]
							}
						}
					]
				},
				{
					"name": "Get Profile (/me)",
					"request": {
						"method": "GET",
						"url": { "raw": "{{base_url}}/api/auth/me/", "host": ["{{base_url}}"], "path": ["api", "auth", "me", ""] }
					}
				},
				{
					"name": "Update Profile",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"phone\": \"9841234567\"\n}"
						},
						"url": { "raw": "{{base_url}}/api/auth/me/", "host": ["{{base_url}}"], "path": ["api", "auth", "me", ""] }
					}
				}
			]
		},
